<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hijau_muda">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/hijau_primary"
        app:titleTextColor="@color/putih_soft"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- WELCOME CARD -->
    <LinearLayout
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@color/hijau_primary"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat Datang"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/putih_soft"/>

        <TextView
            android:id="@+id/textUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Halo, user 👋"
            android:textSize="16sp"
            android:textColor="@color/putih_soft"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- LOGO -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/logoapptiara"
        app:layout_constraintTop_toBottomOf="@id/headerCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- MENU GRID -->

    <Button
        android:id="@+id/btnRumus"
        android:layout_width="150dp"
        android:layout_height="110dp"
        android:text="📐\nRumus"
        android:textStyle="bold"
        android:textColor="@color/putih_soft"
        android:backgroundTint="@color/hijau_primary"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnCustom1"/>

    <Button
        android:id="@+id/btnCustom1"
        android:layout_width="150dp"
        android:layout_height="110dp"
        android:text="⭐\nCustom 1"
        android:textStyle="bold"
        android:textColor="@color/putih_soft"
        android:backgroundTint="@color/hijau_primary"
        android:layout_marginTop="18dp"
        android:layout_marginStart="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toEndOf="@id/btnRumus"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnCustom2"
        android:layout_width="150dp"
        android:layout_height="110dp"
        android:text="🎨\nCustom 2"
        android:textStyle="bold"
        android:textColor="@color/putih_soft"
        android:backgroundTint="@color/hijau_primary"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnRumus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnBinaDesa"/>

    <Button
        android:id="@+id/btnBinaDesa"
        android:layout_width="150dp"
        android:layout_height="110dp"
        android:text="🌐\nWeb Desa"
        android:textStyle="bold"
        android:textColor="@color/putih_soft"
        android:backgroundTint="@color/hijau_primary"
        android:layout_marginTop="14dp"
        android:layout_marginStart="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnCustom1"
        app:layout_constraintStart_toEndOf="@id/btnCustom2"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LOGOUT -->
    <!-- LOGOUT (LEBIH KECIL & POSISI AMAN DI BAWAH) -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="140dp"
        android:layout_height="48dp"
        android:layout_marginBottom="28dp"
        android:backgroundTint="@color/hijau_dark"
        android:text="Logout"
        android:textColor="@color/putih_soft"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>